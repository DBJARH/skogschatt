{
  "rules": {
    "skogschatt": {
      "users": {
        ".read": "auth != null",
        ".write": false
      },
      "messages": {
        ".read": "auth != null && root.child('skogschatt/users/' + auth.token.email.replace('.', ',')).exists()",
        ".write": "auth != null && root.child('skogschatt/users/' + auth.token.email.replace('.', ',')).exists()",
        "$messageId": {
          ".validate": "newData.hasChildren(['user', 'text', 'ts'])"
        }
      }
    }
  }
}
